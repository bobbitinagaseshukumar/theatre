datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — used at runtime
  directUrl = env("DIRECT_URL")   // direct/session — used for migrations & db push
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  STAFF
  MANAGER
  OWNER
  SUPER_ADMIN
}

enum MovieStatus {
  NOW_SHOWING
  UPCOMING
  ARCHIVED
}

enum SeatType {
  STANDARD
  PREMIUM
  VIP
}

enum ShowtimeSeatStatus {
  AVAILABLE
  LOCKED
  BOOKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
}

enum FoodCategory {
  BEVERAGES
  POPCORN
  SNACKS
  COMBOS
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  phone        String?
  role         Role          @default(CUSTOMER)
  isVerified   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bookings          Booking[]
  reviews           Review[]
  activityLogs      ActivityLog[]
  customerProfile   CustomerProfile?
  customerTags      CustomerTag[]
  supportTickets    SupportTicket[]
  customerTimelines CustomerTimeline[]
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Movie {
  id             String      @id @default(uuid())
  title          String
  description    String
  trailerUrl     String?
  posterUrl      String
  bannerUrl      String?
  duration       Int         // in minutes
  releaseDate    DateTime
  language       String[]    // e.g. ["English", "Hindi"]
  genre          String[]    // e.g. ["Action", "Sci-Fi"]
  rating         Float       @default(0.0)
  ageRestriction String      @default("U/A")
  cast           Json        // JSON array of actors: [{name, role, imageUrl}]
  status         MovieStatus @default(UPCOMING)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  showtimes      Showtime[]
  reviews        Review[]
}

model Screen {
  id            String       @id @default(uuid())
  name          String       @unique // e.g. "Screen 1", "IMAX"
  totalRows     Int          @default(10)
  totalCols     Int          @default(15)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  screenSeats   ScreenSeat[]
  showtimes     Showtime[]
}

model ScreenSeat {
  id            String         @id @default(uuid())
  screenId      String
  screen        Screen         @relation(fields: [screenId], references: [id], onDelete: Cascade)
  seatNumber    String         // e.g. "A-1", "J-12"
  row           String         // e.g. "A", "J"
  col           Int            // e.g. 1, 12
  type          SeatType       @default(STANDARD)
  showtimeSeats ShowtimeSeat[]

  @@unique([screenId, seatNumber])
}

model Showtime {
  id            String         @id @default(uuid())
  movieId       String
  movie         Movie          @relation(fields: [movieId], references: [id], onDelete: Cascade)
  screenId      String
  screen        Screen         @relation(fields: [screenId], references: [id], onDelete: Cascade)
  startTime     DateTime
  endTime       DateTime
  basePrice     Float
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  showtimeSeats ShowtimeSeat[]
  bookings      Booking[]
}

model ShowtimeSeat {
  id           String             @id @default(uuid())
  showtimeId   String
  showtime     Showtime           @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  screenSeatId String
  screenSeat   ScreenSeat         @relation(fields: [screenSeatId], references: [id], onDelete: Cascade)
  status       ShowtimeSeatStatus @default(AVAILABLE)
  userId       String?            // User who locked or booked this seat
  lockedUntil  DateTime?          // For seat locking countdown (e.g. 5 minutes)
  bookingId    String?
  booking      Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([showtimeId, screenSeatId])
}

model Booking {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  showtimeId    String
  showtime      Showtime       @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  bookingDate   DateTime       @default(now())
  totalPrice    Float
  status        BookingStatus  @default(PENDING)
  foodItems     Json?          // Array of {foodItemId, quantity, price}
  seatNumbers   String[]       // e.g. ["A-1", "A-2"]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  payments      Payment[]
  showtimeSeats ShowtimeSeat[]
}

model Payment {
  id            String          @id @default(uuid())
  bookingId     String
  booking       Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount        Float
  status        PaymentStatus   @default(PENDING)
  transactionId String?         @unique // Razorpay Order ID or Payment ID
  signature     String?         // Razorpay signature verify
  provider      PaymentProvider @default(RAZORPAY)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model FoodItem {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  price       Float
  imageUrl    String
  category    FoodCategory @default(SNACKS)
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique
  discountValue  Float     // could be percentage or fixed amount
  isPercentage   Boolean   @default(true)
  maxDiscount    Float?    // Cap for percentage discount
  minOrderAmount Float     @default(0.0)
  expiresAt      DateTime
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
}

model Offer {
  id          String   @id @default(uuid())
  title       String
  description String
  imageUrl    String
  code        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Banner {
  id          String   @id @default(uuid())
  imageUrl    String
  title       String
  subtitle    String?
  movieId     String?  // Optional link to details page
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  rating    Int      // 1 to 5 stars
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, movieId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g. "USER_LOGIN", "MOVIE_CREATE"
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "theme_colors", "cancellation_rules", "general_info"
  value     Json     // Dynamic JSON representation
  updatedAt DateTime @updatedAt
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  BOOKING
  PAYMENT
  REFUND
  FOOD
  MEMBERSHIP
  TECHNICAL
  COMPLAINT
  SUGGESTION
  LOST_ITEM
  PARKING
  OTHER
}

enum KitchenOrderStatus {
  RECEIVED
  ACCEPTED
  PREPARING
  PACKED
  READY
  DELIVERED
  CANCELLED
}

model CustomerProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar            String?
  dateOfBirth       DateTime?
  gender            String?
  city              String?
  state             String?
  country           String?   @default("India")
  preferredGenre    String[]
  preferredLanguage String?   @default("English")
  lifetimeSpend     Float     @default(0)
  totalBookings     Int       @default(0)
  averageRating     Float     @default(0)
  satisfactionScore Float     @default(0)
  loyaltyTier       String    @default("Bronze")
  lastLoginAt       DateTime?
  lastBookingAt     DateTime?
  marketingConsent  Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model CustomerTag {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag       String
  color     String   @default("#F59E0B")
  createdAt DateTime @default(now())

  @@unique([userId, tag])
}

model SupportTicket {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       TicketCategory @default(OTHER)
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)
  subject        String
  description    String
  assignedAgent  String?
  resolution     String?
  customerRating Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  replies        SupportReply[]
}

model SupportReply {
  id           String        @id @default(uuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message      String
  isStaffReply Boolean       @default(false)
  senderName   String
  createdAt    DateTime      @default(now())
}

model CustomerTimeline {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     String
  details   String?
  ipAddress String?
  device    String?
  createdAt DateTime @default(now())
}

model FoodCategoryCustom {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  themeColor  String   @default("#F59E0B")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FoodCombo {
  id            String   @id @default(uuid())
  name          String
  description   String?
  items         Json
  originalPrice Float
  comboPrice    Float
  savings       Float
  imageUrl      String?
  badge         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model KitchenOrder {
  id               String             @id @default(uuid())
  bookingId        String?
  customerName     String
  screenName       String?
  seatNumber       String?
  items            Json
  totalAmount      Float
  status           KitchenOrderStatus @default(RECEIVED)
  assignedChef     String?
  notes            String?
  estimatedPrepTime Int               @default(5)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model FoodInventoryItem {
  id             String    @id @default(uuid())
  ingredientName String    @unique
  supplier       String?
  currentStock   Float     @default(0)
  minimumStock   Float     @default(10)
  maximumStock   Float     @default(1000)
  unit           String    @default("units")
  costPerUnit    Float     @default(0)
  expiryDate     DateTime?
  lastRestocked  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ═══════════════════════════════════════════════════
// VOLUME 6 PART 6 — Employee Management System
// ═══════════════════════════════════════════════════

enum EmploymentType {
  PERMANENT
  CONTRACT
  INTERN
  TEMPORARY
  PART_TIME
  FREELANCER
  PROBATION
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
  HALF_DAY
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  EMERGENCY
  COMP_OFF
  LOSS_OF_PAY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  VERIFIED
  REJECTED
}

enum ShiftType {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  WEEKEND
  FESTIVAL
  CUSTOM
}

model Department {
  id            String     @id @default(uuid())
  name          String     @unique
  description   String?
  headName      String?
  employeeCount Int        @default(0)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employees     Employee[]
}

model Employee {
  id               String         @id @default(uuid())
  employeeCode     String         @unique
  firstName        String
  lastName         String
  email            String         @unique
  phone            String?
  avatar           String?
  gender           String?
  dateOfBirth      DateTime?
  bloodGroup       String?
  departmentId     String
  department       Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  designation      String
  employmentType   EmploymentType @default(PERMANENT)
  reportingManager String?
  joiningDate      DateTime       @default(now())
  baseSalary       Float          @default(0)
  currentShift     ShiftType      @default(MORNING)
  performanceScore Float          @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  attendances      AttendanceRecord[]
  leaves           LeaveRequest[]
  tasks            EmployeeTask[]
  payslips         Payslip[]
}

model AttendanceRecord {
  id            String           @id @default(uuid())
  employeeId    String
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  status        AttendanceStatus @default(PRESENT)
  hoursWorked   Float            @default(0)
  overtimeHours Float            @default(0)
  method        String           @default("MANUAL")
  notes         String?
  createdAt     DateTime         @default(now())

  @@unique([employeeId, date])
}

model ShiftSchedule {
  id           String    @id @default(uuid())
  name         String
  shiftType    ShiftType @default(MORNING)
  startTime    String
  endTime      String
  graceMinutes Int       @default(15)
  breakMinutes Int       @default(30)
  maxHours     Float     @default(8)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model LeaveRequest {
  id         String      @id @default(uuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType   @default(CASUAL)
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Payslip {
  id               String    @id @default(uuid())
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month            String
  basicPay         Float
  hra              Float     @default(0)
  da               Float     @default(0)
  specialAllowance Float     @default(0)
  overtime         Float     @default(0)
  bonus            Float     @default(0)
  grossPay         Float
  pfDeduction      Float     @default(0)
  esiDeduction     Float     @default(0)
  tdsDeduction     Float     @default(0)
  otherDeductions  Float     @default(0)
  netPay           Float
  isPaid           Boolean   @default(false)
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
}

model PerformanceReview {
  id               String   @id @default(uuid())
  employeeId       String
  employeeName     String
  department       String
  period           String
  attendanceScore  Float    @default(0)
  punctualityScore Float    @default(0)
  customerRating   Float    @default(0)
  managerRating    Float    @default(0)
  overallScore     Float    @default(0)
  recommendation   String?
  createdAt        DateTime @default(now())
}

model EmployeeTask {
  id          String     @id @default(uuid())
  employeeId  String
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String     @default("General")
  status      TaskStatus @default(PENDING)
  priority    String     @default("MEDIUM")
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Announcement {
  id               String    @id @default(uuid())
  title            String
  message          String
  category         String    @default("General")
  priority         String    @default("NORMAL")
  targetDepartment String?
  isActive         Boolean   @default(true)
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
}

// ═══════════════════════════════════════════════════
// VOLUME 6 PART 7 — Marketing Automation System
// ═══════════════════════════════════════════════════

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
  SOCIAL
  BANNER
}

enum RedemptionType {
  TICKET
  FOOD
  PARKING
  MEMBERSHIP
  CASHBACK
  GIFT_CARD
  MERCHANDISE
}

model MembershipPlan {
  id              String   @id @default(uuid())
  name            String   @unique
  tier            String   @default("Basic")
  description     String?
  monthlyPrice    Float    @default(0)
  quarterlyPrice  Float    @default(0)
  yearlyPrice     Float    @default(0)
  lifetimePrice   Float?
  discountPercent Float    @default(0)
  foodDiscount    Float    @default(0)
  bonusPoints     Int      @default(0)
  priorityBooking Boolean  @default(false)
  freeParking     Boolean  @default(false)
  loungeAccess    Boolean  @default(false)
  maxTickets      Int      @default(0)
  benefits        Json?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  memberships     CustomerMembership[]
}

model CustomerMembership {
  id             String         @id @default(uuid())
  userId         String
  planId         String
  plan           MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  membershipCode String         @unique
  startDate      DateTime       @default(now())
  endDate        DateTime
  autoRenew      Boolean        @default(true)
  isActive       Boolean        @default(true)
  rewardPoints   Int            @default(0)
  walletBalance  Float          @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RewardPoint {
  id          String   @id @default(uuid())
  userId      String
  points      Int
  source      String   @default("PURCHASE")
  description String?
  expiresAt   DateTime?
  isRedeemed  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CouponCampaign {
  id              String    @id @default(uuid())
  code            String    @unique
  title           String
  description     String?
  discountType    String    @default("PERCENTAGE")
  discountValue   Float
  maxDiscount     Float?
  minOrderAmount  Float     @default(0)
  usageLimit      Int       @default(100)
  usedCount       Int       @default(0)
  perCustomerLimit Int      @default(1)
  applicableMovies String[]
  applicableShows  String[]
  applicableFood   String[]
  isStackable     Boolean   @default(false)
  isHidden        Boolean   @default(false)
  isActive        Boolean   @default(true)
  startsAt        DateTime  @default(now())
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  usages          CouponUsage[]
}

model CouponUsage {
  id        String         @id @default(uuid())
  couponId  String
  coupon    CouponCampaign @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  orderId   String?
  discount  Float
  usedAt    DateTime       @default(now())
}

model Referral {
  id             String   @id @default(uuid())
  referrerUserId String
  referredUserId String?
  referralCode   String   @unique
  referralLink   String?
  rewardType     String   @default("POINTS")
  referrerReward Float    @default(0)
  referredReward Float    @default(0)
  isConverted    Boolean  @default(false)
  convertedAt    DateTime?
  createdAt      DateTime @default(now())
}

model MarketingCampaign {
  id              String         @id @default(uuid())
  name            String
  description     String?
  channel         CampaignChannel @default(EMAIL)
  status          CampaignStatus  @default(DRAFT)
  targetSegment   String?
  subject         String?
  content         String?
  sendAt          DateTime?
  sentCount       Int            @default(0)
  openCount       Int            @default(0)
  clickCount      Int            @default(0)
  conversionCount Int            @default(0)
  revenue         Float          @default(0)
  budget          Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ScratchCard {
  id            String   @id @default(uuid())
  campaignName  String
  rewardType    String   @default("POINTS")
  rewardValue   Float    @default(0)
  probability   Float    @default(0.5)
  totalCards     Int      @default(1000)
  scratchedCount Int     @default(0)
  isActive      Boolean  @default(true)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
}

model LuckyDraw {
  id            String    @id @default(uuid())
  name          String
  description   String?
  prizeType     String
  prizeValue    String
  entryRule      String?
  totalEntries  Int       @default(0)
  winnerId      String?
  winnerName    String?
  isDrawn       Boolean   @default(false)
  drawDate      DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model CustomerSegment {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  criteria    Json?
  customerCount Int    @default(0)
  isAutomatic Boolean  @default(false)
  color       String   @default("#6366F1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MarketingAutomation {
  id          String   @id @default(uuid())
  name        String
  trigger     String
  actions     Json
  isActive    Boolean  @default(true)
  executions  Int      @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════
// VOLUME 6 PART 8 — Enterprise Finance Management
// ═══════════════════════════════════════════════════

model BankAccount {
  id             String            @id @default(uuid())
  name           String
  type           String            @default("Bank") // Current, Savings, Cash, UPI, Wallet
  openingBalance Float             @default(0)
  currentBalance Float             @default(0)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  transactions   BankTransaction[]
}

model BankTransaction {
  id              String      @id @default(uuid())
  accountId       String
  account         BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type            String      // INFLOW, OUTFLOW
  amount          Float
  description     String?
  reference       String?
  transactionDate DateTime    @default(now())
  createdAt       DateTime    @default(now())
}

model RevenueRecord {
  id               String   @id @default(uuid())
  source           String   // Movie Tickets, Food Orders, Membership, Parking, etc.
  amount           Float
  taxPaid          Float    @default(0)
  ledgerCode       String?
  department       String?
  branch           String?
  date             DateTime @default(now())
  createdAt        DateTime @default(now())
}

model ExpenseRecord {
  id            String    @id @default(uuid())
  invoiceNumber String?
  vendor        String
  category      String
